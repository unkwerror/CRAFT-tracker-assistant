# Яндекс OAuth
YANDEX_CLIENT_ID=your_client_id
YANDEX_CLIENT_SECRET=your_client_secret
NEXT_PUBLIC_YANDEX_CLIENT_ID=your_client_id
YANDEX_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Публичный URL приложения (для корректных redirect на Render/Prod)
NEXT_PUBLIC_APP_URL=https://craft-assistant.onrender.com

# Сессия (сгенерировать случайную строку)
SESSION_SECRET=your_random_secret_32_chars_min

# PostgreSQL
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Яндекс Трекер (ID организации)
TRACKER_ORG_ID=your_org_id
TRACKER_SYNC_TOKEN=

# Sync cron secret
SYNC_SECRET=change-me-random-string

# Rive Brand Illustration (опционально)
# Путь до .riv файла, например: /rive/craft-dashboard.riv
NEXT_PUBLIC_RIVE_BRAND_SRC=
# Имя state machine внутри Rive
NEXT_PUBLIC_RIVE_BRAND_SM=
# Вариант 1: числовой input состояния (0=idle,1=loading,2=success,3=error)
NEXT_PUBLIC_RIVE_BRAND_STATE_INPUT=
# Вариант 2: bool inputs (один input на каждое состояние)
NEXT_PUBLIC_RIVE_BRAND_BOOL_IDLE=
NEXT_PUBLIC_RIVE_BRAND_BOOL_LOADING=
NEXT_PUBLIC_RIVE_BRAND_BOOL_SUCCESS=
NEXT_PUBLIC_RIVE_BRAND_BOOL_ERROR=
# Вариант 3: trigger inputs (срабатывают при смене состояния)
NEXT_PUBLIC_RIVE_BRAND_TRIGGER_IDLE=
NEXT_PUBLIC_RIVE_BRAND_TRIGGER_LOADING=
NEXT_PUBLIC_RIVE_BRAND_TRIGGER_SUCCESS=
NEXT_PUBLIC_RIVE_BRAND_TRIGGER_ERROR=
