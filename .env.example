# ═══ Обязательные ═══
SESSION_SECRET=random-string-32-chars-change-me
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ═══ Яндекс OAuth ═══
YANDEX_CLIENT_ID=your_client_id
YANDEX_CLIENT_SECRET=your_client_secret
NEXT_PUBLIC_YANDEX_CLIENT_ID=same_client_id
YANDEX_REDIRECT_URI=https://your-app.onrender.com/api/auth/callback

# ═══ Опциональные ═══
# TRACKER_ORG_ID=your_org_id
# NODE_ENV=production
