# ═══════════════════════════════════════
# Крафт Ассистент — переменные окружения
# Скопируйте в .env.local и заполните
# ═══════════════════════════════════════

# ─── Yandex OAuth ───
# Создать: https://oauth.yandex.ru/ → Создать → Для доступа к API
# Разрешения: tracker:read, tracker:write
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ─── Yandex Tracker ───
# ОПЦИОНАЛЬНО на этапе разработки
# Получить: Трекер → Администрирование → Организации → ID
# Без этого параметра прокси к Трекеру не работает, но авторизация и онбординг — работают
TRACKER_ORG_ID=

# ─── Supabase (бесплатная PostgreSQL) ───
# Создать: https://supabase.com/dashboard → New Project
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─── Приложение ───
APP_URL=http://localhost:3000
SESSION_SECRET=замените_на_случайную_строку_минимум_32_символа
